# Dispatched — environment variables.
# Copy to .env.local (gitignored) and fill in for local dev.
# Render injects these from the dashboard in production.

NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_SUPPORT_PHONE=+13073170801
SENTRY_DSN=
DATABASE_URL=

# Lendflow widget — paste the FULL <script src> from the Lendflow dashboard
# (Integrations → Widget Integration → Step 8 "Embedded" toggle → Copy).
# Carries env, workflowTemplateId, consentTemplateId, destination[*], and
# targetId in one URL. Different value per environment (sandbox vs prod).
# Public — ships to the browser. To re-brand, change workflow, or change
# the redirect destination, regenerate in the dashboard and replace.
NEXT_PUBLIC_LENDFLOW_WIDGET_SCRIPT_SRC=

# Lendflow webhook receiver — request from Lendflow Customer Success.
# Used by /api/webhooks/lendflow to verify HMAC-SHA256 signatures.
LENDFLOW_WEBHOOK_SECRET=
