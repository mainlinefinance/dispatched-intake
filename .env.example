# Dispatched — environment variables.
# Copy to .env.local (gitignored) and fill in for local dev.
# Render injects these from the dashboard in production.

NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_SUPPORT_PHONE=+13073170801
SENTRY_DSN=
DATABASE_URL=

# Lendflow widget — public client id from dashboard Integrations → Widget Integration.
# Sandbox host: https://sandbox-widget.lendflow.com
# Production host: https://widget.lendflow.com
NEXT_PUBLIC_LENDFLOW_WIDGET_ENV_ID=
NEXT_PUBLIC_LENDFLOW_WIDGET_HOST=https://sandbox-widget.lendflow.com
# Branding template id from Customize → Branding (e.g. 284 for the "Dispatched" template).
# Leave blank to use Lendflow default branding.
NEXT_PUBLIC_LENDFLOW_WIDGET_BRANDING_ID=

# Lendflow webhook receiver — request from Lendflow Customer Success.
# Used by /api/webhooks/lendflow to verify HMAC-SHA256 signatures.
LENDFLOW_WEBHOOK_SECRET=
