# Dispatched — environment variables.
# Copy to .env.local (gitignored) and fill in for local dev.
# Render injects these from the dashboard in production.

NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_SUPPORT_PHONE=+13073170801
SENTRY_DSN=
DATABASE_URL=

# Lendflow widget — paste the FULL <script src> from the Lendflow dashboard
# (Integrations → Widget Integration → Step 8 "Embedded" toggle → Copy).
# Carries env, workflowTemplateId, consentTemplateId, destination[*], and
# targetId in one URL. Different value per environment (sandbox vs prod).
# Public — ships to the browser. To re-brand, change workflow, or change
# the redirect destination, regenerate in the dashboard and replace.
NEXT_PUBLIC_LENDFLOW_WIDGET_SCRIPT_SRC=

# Lendflow webhook receiver — request from Lendflow Customer Success.
# Used by /api/webhooks/lendflow to verify HMAC-SHA256 signatures.
LENDFLOW_WEBHOOK_SECRET=

# Coverdash producer-partner embed (used on /insurance and below).
# Coverdash is the named licensed insurance producer for the trucking
# insurance funnel. They hold the carrier appointments and bind policies;
# Dispatched routes intent to them.
#
# Three render modes; the component picks the first one whose vars are set:
#   1. Widget — set NEXT_PUBLIC_COVERDASH_WIDGET_SCRIPT_SRC
#      Loads the official Coverdash bundle and mounts <coverdash-embed>.
#      This is the preferred path once Coverdash BD delivers the script src
#      tagged to our partner license.
#   2. Iframe — set NEXT_PUBLIC_COVERDASH_QUOTES_BASE_URL +
#      NEXT_PUBLIC_COVERDASH_LICENSE_ID. Mirrors the Coverdash × Zeni
#      page pattern: an <iframe> to {base}?license={id}&prefilled_*.
#   3. Deeplink fallback — neither set. Renders product CTAs that route to
#      /apply so the conversion surface is never dead.
#
# License ID + quote-engine origin are public identifiers (visible in the
# Zeni partner page URL). No secret material lives in NEXT_PUBLIC_ vars.
NEXT_PUBLIC_COVERDASH_LICENSE_ID=
NEXT_PUBLIC_COVERDASH_QUOTES_BASE_URL=
NEXT_PUBLIC_COVERDASH_WIDGET_SCRIPT_SRC=

# Search engine site verification tokens. Used by app/layout.tsx to emit
# <meta name="google-site-verification"> and <meta name="msvalidate.01">.
# - Get the Google token from Search Console: Settings → Ownership
#   verification → "HTML tag" method → copy the content="..." value.
# - Get the Bing token from Bing Webmaster Tools: Settings → Ownership
#   → "Meta tag" method → copy the content="..." value.
# Both are public — they're emitted in <head>. Leaving them blank is safe;
# the tags simply won't render until they're set in Render dashboard env.
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# Bearer secret for the IndexNow cron route at /api/cron/indexnow.
# Set to a random 32+ char string. Generate: openssl rand -hex 32
# In the Render dashboard, set the SAME value on both the web service
# AND the indexnow-ping cron job — the route returns 401 if the bearer
# in the cron's curl call doesn't match the web service's env var.
# Locally: only needed if you want to hit /api/cron/indexnow during dev.
CRON_SECRET=

# Optional: override the IndexNow key the route submits with. The default
# is the value baked into the static file at
# public/f7d09b96f43c7976a9a6e1f50552181f.txt. Only change this if you've
# rotated the key AND replaced/renamed the static file in /public to
# match — IndexNow verifies the key by fetching keyLocation.
# Generate a new key with: openssl rand -hex 16
INDEXNOW_KEY=

# Optional: override the host IndexNow claims ownership of. Defaults to
# dispatched.finance (or the hostname of NEXT_PUBLIC_SITE_URL if set).
INDEXNOW_HOST=
